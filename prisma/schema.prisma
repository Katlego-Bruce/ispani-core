generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum PaymentStatus {
  PENDING
  HELD
  RELEASED
  REFUNDED
  DISPUTED
}

model User {
  id                   String    @id @default(uuid())
  firstName            String
  lastName             String
  phone                String    @unique
  email                String?   @unique
  password             String
  skills               String[]
  location             String?
  bio                  String?
  latitude             Float?
  longitude            Float?
  lastLocationUpdateAt DateTime?
  isOnline             Boolean   @default(false)
  isAdmin              Boolean   @default(false)
  isSuspended          Boolean   @default(false)
  isBanned             Boolean   @default(false)
  fcmToken             String?
  averageRating        Float     @default(0)
  completedJobs        Int       @default(0)
  cancelledJobs        Int       @default(0)
  totalJobsAccepted    Int       @default(0)
  userLevel            Int       @default(1)
  popiaConsentAt       DateTime?
  deletedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  jobs             Job[]
  applications     Application[]
  assignedJobs     Job[]          @relation("AssignedUser")
  reviewsGiven     Review[]       @relation("ReviewsGiven")
  reviewsReceived  Review[]       @relation("ReviewsReceived")
  paymentsMade     Payment[]      @relation("PaymentsMade")
  paymentsReceived Payment[]      @relation("PaymentsReceived")
  refreshTokens    RefreshToken[]

  @@index([deletedAt])
  @@index([latitude, longitude])
  @@index([isOnline])
  @@index([isAdmin])
}

model Job {
  id          String    @id @default(uuid())
  title       String
  description String
  budget      Decimal   @db.Decimal(10, 2)
  location    String
  category    String?
  latitude    Float?
  longitude   Float?
  status      JobStatus @default(OPEN)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedToId String?
  assignedTo   User?         @relation("AssignedUser", fields: [assignedToId], references: [id])
  applications Application[]
  reviews      Review[]
  payment      Payment?

  @@index([status])
  @@index([category])
  @@index([userId])
  @@index([assignedToId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([latitude, longitude])
}

model Application {
  id        String            @id @default(uuid())
  message   String?
  status    ApplicationStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  jobId       String
  job         Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicantId String
  applicant   User   @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([jobId, applicantId])
  @@index([applicantId])
  @@index([status])
}

model Review {
  id         String   @id @default(uuid())
  rating     Int
  comment    String?
  reviewerId String
  reviewer   User     @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  revieweeId String
  reviewee   User     @relation("ReviewsReceived", fields: [revieweeId], references: [id])
  jobId      String
  job        Job      @relation(fields: [jobId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([reviewerId, jobId])
  @@index([revieweeId])
  @@index([rating])
}

model Payment {
  id           String        @id @default(uuid())
  amount       Decimal       @db.Decimal(10, 2)
  serviceFee   Decimal       @db.Decimal(10, 2)
  workerPayout Decimal       @db.Decimal(10, 2)
  status       PaymentStatus @default(PENDING)
  jobId        String        @unique
  job          Job           @relation(fields: [jobId], references: [id])
  clientId     String
  client       User          @relation("PaymentsMade", fields: [clientId], references: [id])
  workerId     String?
  worker       User?         @relation("PaymentsReceived", fields: [workerId], references: [id])
  heldAt       DateTime?
  releasedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status])
  @@index([clientId])
  @@index([workerId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  phone     String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([token])
  @@index([expiresAt])
}

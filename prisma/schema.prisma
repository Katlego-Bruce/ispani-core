generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────
enum UserRole {
  CLIENT
  WORKER
}

enum JobStatus {
  OPEN
  ASSIGNED
  COMPLETED
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ─── Models ───────────────────────────────────────────────
model User {
  id                   String    @id @default(uuid())
  firstName            String
  lastName             String
  phone                String    @unique
  email                String?   @unique
  password             String
  role                 UserRole
  skills               String[]
  location             String?
  bio                  String?
  latitude             Float?                    // GPS latitude
  longitude            Float?                    // GPS longitude
  lastLocationUpdateAt DateTime?                 // When location was last refreshed
  isOnline             Boolean   @default(false) // Worker availability flag
  deletedAt            DateTime?                 // Soft delete
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  jobs         Job[]
  applications Application[]

  @@index([role])
  @@index([deletedAt])
  @@index([latitude, longitude])
  @@index([isOnline])
}

model Job {
  id          String    @id @default(uuid())
  title       String
  description String
  budget      Decimal   @db.Decimal(10, 2)  // Precise monetary values
  location    String
  category    String?
  latitude    Float?                         // Job site latitude
  longitude   Float?                         // Job site longitude
  status      JobStatus @default(OPEN)
  deletedAt   DateTime?                      // Soft delete
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([status])
  @@index([category])
  @@index([userId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([latitude, longitude])
}

model Application {
  id        String            @id @default(uuid())
  message   String?
  status    ApplicationStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  jobId    String
  job      Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  workerId String
  worker   User   @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([jobId, workerId])
  @@index([workerId])
  @@index([status])
}

{
  "name": "ispani-core",
  "version": "2.3.0",
  "description": "ISPANI - South African Digital Labour Marketplace Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "NODE_ENV=test jest --runInBand",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:coverage": "NODE_ENV=test jest --coverage",
    "lint": "eslint src/",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "node prisma/seed.js"
  },
  "keywords": ["ispani", "labour", "marketplace", "south-africa"],
  "author": "Katlego-Bruce",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "argon2": "^0.44.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pino": "^9.14.0",
    "pino-http": "^9.0.0",
    "uuid": "^11.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2"
  },
  "engines": { "node": ">=20.0.0" }
}

    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "@prisma/client": "^5.7.1",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "uuid": "^9.0.0",
    "twilio": "^4.23.0",
    "firebase-admin": "^12.0.0",
    "ioredis": "^5.3.2"

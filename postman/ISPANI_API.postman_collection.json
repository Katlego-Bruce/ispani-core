{
  "info": {
    "name": "ISPANI API",
    "description": "Full E2E test collection for ISPANI - South African Digital Labour Marketplace",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "clientToken",
      "value": ""
    },
    {
      "key": "workerToken",
      "value": ""
    },
    {
      "key": "jobId",
      "value": ""
    },
    {
      "key": "applicationId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "1.1 Register Client",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"firstName\": \"Thabo\", \"lastName\": \"Mokoena\", \"phone\": \"0711111111\", \"password\": \"securePass123\", \"role\": \"client\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('clientToken', data.data.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "1.2 Register Worker",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"firstName\": \"Sipho\", \"lastName\": \"Dlamini\", \"phone\": \"0722222222\", \"password\": \"securePass123\", \"role\": \"worker\", \"skills\": [\"plumbing\", \"electrical\"]}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('workerToken', data.data.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "1.3 Login Client",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"phone\": \"0711111111\", \"password\": \"securePass123\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('clientToken', data.data.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "1.4 Get Current User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{clientToken}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has user data', () => pm.expect(pm.response.json().data.firstName).to.eql('Thabo'));"
                ]
              }
            }
          ]
        },
        {
          "name": "1.5 Register Duplicate (should fail)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"firstName\": \"Thabo\", \"lastName\": \"Mokoena\", \"phone\": \"0711111111\", \"password\": \"securePass123\", \"role\": \"client\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409 Conflict', () => pm.response.to.have.status(409));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Jobs",
      "item": [
        {
          "name": "2.1 Create Job (Client)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/jobs",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{clientToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Fix leaking tap in kitchen\", \"description\": \"Kitchen tap has been leaking for a week. Need someone experienced to fix it.\", \"budget\": 350, \"location\": \"Sandton\", \"category\": \"plumbing\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('jobId', data.data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "2.2 Create Job as Worker (should fail)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/jobs",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{workerToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Test job\", \"description\": \"Workers should not create jobs\", \"budget\": 100, \"location\": \"Test\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 Forbidden', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ]
        },
        {
          "name": "2.3 List All Jobs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/jobs"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has jobs array', () => pm.expect(pm.response.json().data.jobs).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "2.4 Get Job By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/jobs/{{jobId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has correct title', () => pm.expect(pm.response.json().data.title).to.include('tap'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3. Applications",
      "item": [
        {
          "name": "3.1 Worker Applies to Job",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/jobs/{{jobId}}/apply",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{workerToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"message\": \"I have 5 years plumbing experience. Can fix this today.\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('applicationId', data.data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "3.2 Worker Applies Again (should fail)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/jobs/{{jobId}}/apply",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{workerToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"message\": \"Duplicate application\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409 Conflict', () => pm.response.to.have.status(409));"
                ]
              }
            }
          ]
        },
        {
          "name": "3.3 Client Views Applications",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/jobs/{{jobId}}/applications",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{clientToken}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has applications', () => pm.expect(pm.response.json().data).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "3.4 Client Accepts Application",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/jobs/{{jobId}}/applications/{{applicationId}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{clientToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"status\": \"accepted\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status accepted', () => pm.expect(pm.response.json().data.status).to.eql('accepted'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4. Job Lifecycle",
      "item": [
        {
          "name": "4.1 Complete Job",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/jobs/{{jobId}}/complete",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{clientToken}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status completed', () => pm.expect(pm.response.json().data.status).to.eql('completed'));"
                ]
              }
            }
          ]
        },
        {
          "name": "4.2 Cancel Completed Job (should fail)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/jobs/{{jobId}}/cancel",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{clientToken}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "5. Users",
      "item": [
        {
          "name": "5.1 List Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{clientToken}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "5.2 Filter Workers Only",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users?role=worker",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{clientToken}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('All are workers', () => {",
                  "  const users = pm.response.json().data.users;",
                  "  users.forEach(u => pm.expect(u.role).to.eql('worker'));",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "6. Edge Cases",
      "item": [
        {
          "name": "6.1 No Token (should 401)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "6.2 Invalid Token (should 401)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer invalid.token.here"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "6.3 404 Route",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/nonexistent"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        },
        {
          "name": "6.4 Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}